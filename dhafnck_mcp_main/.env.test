# Test Environment Configuration
# This file contains environment variables specifically for testing

# Testing Mode
TESTING=true
ENVIRONMENT=test

# Database Configuration for Tests
DATABASE_URL=sqlite:///dhafnck_mcp_test.db
TEST_DATABASE_URL=sqlite:///dhafnck_mcp_test.db
MCP_DB_PATH=./dhafnck_mcp_test.db

# Schema Base Path
SCHEMA_BASE_PATH=database/schema

# Python Path
PYTHONPATH=src:tests

# Logging for Tests
LOG_LEVEL=WARNING
TEST_LOG_LEVEL=DEBUG

# Disable Telemetry in Tests
DISABLE_TELEMETRY=true

# Test-specific Settings
PYTEST_CURRENT_TEST=1
TEST_ISOLATION=true
USE_TEST_DATABASE=true

# Performance Settings for Tests
TEST_TIMEOUT=300
TEST_PARALLEL_WORKERS=auto

# Coverage Settings
COVERAGE_ENABLED=true
COVERAGE_MIN_PERCENTAGE=80

# MCP Server Test Configuration
MCP_TEST_MODE=true
MCP_TEST_PORT=8001