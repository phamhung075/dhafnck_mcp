# Supabase Configuration Template
# Copy this file to .env and fill in your Supabase project details
# You can find these values in your Supabase dashboard: https://app.supabase.com

# ==============================================================================
# REQUIRED: Database Type Configuration
# ==============================================================================
# Set to "supabase" for Supabase cloud, "postgresql" for local PostgreSQL
DATABASE_TYPE=supabase

# ==============================================================================
# REQUIRED: Supabase Project Configuration
# ==============================================================================
# Your Supabase project URL (format: https://[project-ref].supabase.co)
SUPABASE_URL=https://your-project-ref.supabase.co

# Your Supabase anonymous key (found in Settings > API)
SUPABASE_ANON_KEY=your-anon-key-here

# ==============================================================================
# REQUIRED: Supabase Database Connection
# ==============================================================================
# Option 1: Direct database URL (recommended - found in Settings > Database)
SUPABASE_DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# Option 2: Individual connection parameters
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_DB_HOST=db.your-project-ref.supabase.co
# SUPABASE_DB_PORT=5432
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres

# ==============================================================================
# OPTIONAL: Additional Supabase Configuration
# ==============================================================================
# Service role key for admin operations (found in Settings > API)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# JWT secret for token verification (found in Settings > API > JWT Settings)
SUPABASE_JWT_SECRET=your-jwt-secret-here

# ==============================================================================
# OPTIONAL: Performance and Debug Settings
# ==============================================================================
# Enable SQL query logging (true/false)
SQL_DEBUG=false

# Redis cache configuration (if using Redis with Supabase)
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password

# ==============================================================================
# FALLBACK: PostgreSQL Configuration
# ==============================================================================
# If Supabase is not configured, the system will fall back to PostgreSQL
# Set DATABASE_TYPE=postgresql and configure this URL:
# DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# ==============================================================================
# TESTING: SQLite Configuration (Development Only)
# ==============================================================================
# For testing purposes only - not for production
# DATABASE_TYPE=sqlite
# MCP_DB_PATH=./test.db

# ==============================================================================
# HOW TO USE THIS FILE:
# ==============================================================================
# 1. Copy this file: cp .env.supabase.template .env
# 2. Log in to your Supabase dashboard: https://app.supabase.com
# 3. Go to Settings > API to find your project URL and keys
# 4. Go to Settings > Database to find your connection string
# 5. Replace all placeholder values with your actual Supabase credentials
# 6. Restart your application to apply the new configuration
#
# SECURITY NOTE: Never commit the .env file to version control!
# Add .env to your .gitignore file to prevent accidental commits.
#
# TROUBLESHOOTING:
# - If you see "SUPABASE NOT PROPERLY CONFIGURED!" error:
#   1. Ensure all required variables are set (SUPABASE_URL, SUPABASE_ANON_KEY, and either SUPABASE_DATABASE_URL or SUPABASE_DB_PASSWORD)
#   2. Check that your Supabase project is active and not paused
#   3. Verify your database password is correct
#   4. Ensure your IP address is allowed in Supabase (Settings > Database > Connection Pooling)
#
# - If performance is slow with Supabase:
#   1. Consider using connection pooling (Settings > Database > Connection Pooling)
#   2. Use the pooler connection string instead of direct connection
#   3. Set DATABASE_TYPE=postgresql to use local PostgreSQL for better performance