# =============================================================================
# SECURE ENVIRONMENT CONFIGURATION TEMPLATE - DHAFNCK MCP PROJECT
# =============================================================================
# IMPORTANT: This is a template. Copy to .env and fill with your actual values
# NEVER commit .env file with real credentials to version control
# =============================================================================

# =============================================================================
# ENVIRONMENT SETTINGS
# =============================================================================
ENV=dev
NODE_ENV=development
APP_ENV=development
ENVIRONMENT=development
APP_DEBUG=true
APP_LOG_LEVEL=INFO
DHAFNCK_MVP_MODE=true
DHAFNCK_AUTH_ENABLED=false

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_TYPE=supabase

# SUPABASE DATABASE - Replace with your actual values
# Get these from your Supabase dashboard: https://app.supabase.com/project/YOUR_PROJECT/settings/database
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Database connection - Use environment variables, not hardcoded values
SUPABASE_DB_HOST=YOUR_PROJECT_REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=YOUR_DATABASE_PASSWORD_HERE

# Construct DATABASE_URL from environment variables (do not hardcode)
# This will be constructed by the application from the above variables

# =============================================================================
# REDIS CACHE
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=YOUR_REDIS_PASSWORD_HERE
REDIS_DB=0

# =============================================================================
# SECURITY NOTES
# =============================================================================
# 1. NEVER commit real credentials to version control
# 2. Use a password manager or secure vault for production credentials
# 3. Rotate credentials regularly, especially after exposure
# 4. Use different credentials for dev, staging, and production
# 5. Enable 2FA on your Supabase account
# 6. Restrict database access by IP address when possible
# 7. Use read-only credentials where write access is not needed